# Example CMake toolchain: build on Linux x86_64 (or any host with the
# aarch64-linux-gnu cross compiler) for target aarch64-linux-gnu.
#
# Usage:
#   cmake -S . -B build_cross -G Ninja \
#     -DCMAKE_TOOLCHAIN_FILE=cmake/toolchains/aarch64-linux-gnu.cmake \
#     -DCMAKE_PREFIX_PATH=/path/to/aarch64/sysroot/usr
#
# Copy to aarch64-linux-gnu.cmake and adjust paths for your distro.
# See docs/tutorials/modern-cpp-tooling-arm-intel.md

set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR aarch64)

set(CMAKE_C_COMPILER   aarch64-linux-gnu-gcc)
set(CMAKE_CXX_COMPILER aarch64-linux-gnu-g++)

# Optional: explicit sysroot if not using multiarch defaults
# set(CMAKE_SYSROOT /path/to/sysroot)

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)

# Conservative portable AArch64 baseline (override as needed)
set(CMAKE_C_FLAGS_INIT   "-march=armv8-a")
set(CMAKE_CXX_FLAGS_INIT "-march=armv8-a")
