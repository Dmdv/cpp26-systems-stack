# Example CMake toolchain: cross-compile to x86_64-linux-gnu
# (e.g. from an aarch64 Linux host with g++-x86-64-linux-gnu installed).
#
# Usage:
#   cmake -S . -B build_cross_x64 -G Ninja \
#     -DCMAKE_TOOLCHAIN_FILE=cmake/toolchains/x86_64-linux-gnu.cmake \
#     -DCMAKE_PREFIX_PATH=/path/to/x86_64/sysroot/usr
#
# See docs/tutorials/modern-cpp-tooling-arm-intel.md

set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)

set(CMAKE_C_COMPILER   x86_64-linux-gnu-gcc)
set(CMAKE_CXX_COMPILER x86_64-linux-gnu-g++)

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)

# Portable server baseline (SSE4.2-era+). Raise to v3 for AVX2 fleets.
set(CMAKE_C_FLAGS_INIT   "-march=x86-64-v2")
set(CMAKE_CXX_FLAGS_INIT "-march=x86-64-v2")
